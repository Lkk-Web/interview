{
  "schemes": ["http", "https"],
  "swagger": "2.0",
  "info": {
    "description": "个人知识库后端服务，提供股票仪表盘和代码内容管理接口。",
    "title": "Interview Server API",
    "contact": {},
    "version": "1.0"
  },
  "host": "localhost:8888",
  "basePath": "/api",
  "paths": {
    "/admin/stock/asset-history": {
      "post": {
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "新增资产快照",
        "parameters": [
          {
            "description": "资产快照数据",
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/http.CreateAssetHistoryRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/http.AssetHistoryDTO"
            }
          },
          "400": {
            "description": "Bad Request",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/admin/stock/daily-log": {
      "post": {
        "consumes": ["application/json"],
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "提交每日收盘记录",
        "parameters": [
          {
            "description": "每日收盘数据",
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/http.CreateDailyLogRequest"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/code-sources/pages/{pageKey}": {
      "get": {
        "description": "返回指定 pageKey 下的所有公开记录，前端可用来一次性预加载整页数据。",
        "produces": ["application/json"],
        "tags": ["code-sources"],
        "summary": "批量获取页面代码内容",
        "parameters": [
          {
            "type": "string",
            "description": "页面/业务域 key，如 expand-mermaid",
            "name": "pageKey",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/http.CodeSourceListResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/code-sources/pages/{pageKey}/{codeKey}": {
      "get": {
        "description": "按 pageKey + codeKey 精确查询，找不到返回 404。前端 useCodeSource hook 对接此接口。",
        "produces": ["application/json"],
        "tags": ["code-sources"],
        "summary": "获取代码内容",
        "parameters": [
          {
            "type": "string",
            "description": "页面/业务域 key，如 summary-editor",
            "name": "pageKey",
            "in": "path",
            "required": true
          },
          {
            "type": "string",
            "description": "内容 key，如 demo-mermaid",
            "name": "codeKey",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/http.CodeSourceDTO"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/code-sources/pages/{pageKey}/{codeKey}/versions": {
      "get": {
        "description": "返回指定 pageKey + codeKey 记录的历史版本列表，按版本号倒序排列。",
        "produces": ["application/json"],
        "tags": ["code-sources"],
        "summary": "获取代码内容编辑历史",
        "parameters": [
          {
            "type": "string",
            "description": "页面/业务域 key",
            "name": "pageKey",
            "in": "path",
            "required": true
          },
          {
            "type": "string",
            "description": "内容 key",
            "name": "codeKey",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.CodeSourceVersionDTO"
              }
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/asset-history": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取资产历史曲线",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.AssetHistoryDTO"
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/dashboard": {
      "get": {
        "description": "一次返回资产历史、持仓、月度收益、其他收入，前端 StockDashboard 直接消费。",
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取股票仪表盘聚合数据",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/http.DashboardResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/monthly": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取月度 T 收益",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.MonthlyDTO"
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/other-income": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取其他收入/支出",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.OtherIncomeDTO"
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/position-snapshot-as-of/{date}": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取某天或之前最近一次的持仓快照",
        "parameters": [
          {
            "type": "string",
            "description": "YYYY-MM-DD",
            "name": "date",
            "in": "path",
            "required": true
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/http.PositionSnapshotAsOfDTO"
            }
          },
          "404": {
            "description": "Not Found",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/position-snapshots": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取所有有持仓快照的日期明细",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/http.PositionSnapshotDatesDTO"
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/positions": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取当前持仓",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.PositionDTO"
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    },
    "/stock/unmatched-positions": {
      "get": {
        "produces": ["application/json"],
        "tags": ["stock"],
        "summary": "获取未匹配做T仓位",
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/http.UnmatchedLegDTO"
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "schema": {
              "$ref": "#/definitions/httpx.ErrorResponse"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "http.AssetHistoryDTO": {
      "type": "object",
      "properties": {
        "cash": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "loan": {
          "type": "number"
        },
        "other": {
          "type": "number"
        },
        "remark": {
          "type": "string"
        },
        "stockValue": {
          "type": "number"
        }
      }
    },
    "http.CodeSourceDTO": {
      "type": "object",
      "properties": {
        "cacheKey": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "codeKey": {
          "type": "string"
        },
        "defaultOpen": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "editorHeight": {
          "type": "integer"
        },
        "lang": {
          "type": "string"
        },
        "pageKey": {
          "type": "string"
        },
        "theme": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string"
        },
        "zoomable": {
          "type": "boolean"
        }
      }
    },
    "http.CodeSourceListResponse": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.CodeSourceDTO"
          }
        }
      }
    },
    "http.CodeSourceVersionDTO": {
      "type": "object",
      "properties": {
        "changeNote": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        }
      }
    },
    "http.ConsumedLegRequest": {
      "type": "object",
      "required": ["legId"],
      "properties": {
        "consumedShares": {
          "type": "number"
        },
        "legId": {
          "type": "integer"
        }
      }
    },
    "http.CreateAssetHistoryRequest": {
      "type": "object",
      "required": ["date"],
      "properties": {
        "cash": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "loan": {
          "type": "number"
        },
        "other": {
          "type": "number"
        },
        "remark": {
          "type": "string"
        },
        "stockValue": {
          "type": "number"
        }
      }
    },
    "http.CreateDailyLogRequest": {
      "type": "object",
      "required": ["date"],
      "properties": {
        "consumedLegs": {
          "description": "ConsumedLegs 是本次提交消耗掉的历史未匹配腿，后端据此扣减 stock_unmatched_legs。",
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.ConsumedLegRequest"
          }
        },
        "date": {
          "type": "string"
        },
        "marker": {
          "description": "\"！\"=当日有操作 / \"\"=无操作",
          "type": "string"
        },
        "monthlySwingRevenue": {
          "description": "MonthlySwingRevenue 是本月波段收益的最新累计净收益（由前端基于历史值+当日增量计算后传入）。",
          "type": "number"
        },
        "monthlyTRevenue": {
          "description": "MonthlyTRevenue 是本月做T的最新累计净收益（由前端基于历史值+当日增量计算后传入）。",
          "type": "number"
        },
        "newUnmatchedLegs": {
          "description": "NewUnmatchedLegs 是当日新产生、仍未匹配完的腿，会持久化等待未来撮合。",
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.UnmatchedLegRequest"
          }
        },
        "positions": {
          "description": "Positions 是当日收盘后的最新持仓成本和数量。",
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.PositionUpdateRequest"
          }
        },
        "review": {
          "$ref": "#/definitions/http.ReviewRequest"
        },
        "swingRecords": {
          "description": "SwingRecords 是当日跨日撮合成功的波段收益明细，撮合计算在前端完成后提交。",
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.SwingRecordRequest"
          }
        },
        "tRecords": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.TRecordRequest"
          }
        },
        "trades": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.TradeRequest"
          }
        }
      }
    },
    "http.DashboardResponse": {
      "type": "object",
      "properties": {
        "assetHistory": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.AssetHistoryDTO"
          }
        },
        "monthly": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.MonthlyDTO"
          }
        },
        "otherIncome": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.OtherIncomeDTO"
          }
        },
        "positions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.PositionDTO"
          }
        }
      }
    },
    "http.MonthlyDTO": {
      "type": "object",
      "properties": {
        "month": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        },
        "swingRevenue": {
          "type": "number"
        },
        "tRevenue": {
          "type": "number"
        },
        "tTarget": {
          "type": "number"
        }
      }
    },
    "http.OtherIncomeDTO": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "desc": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        }
      }
    },
    "http.PositionBaseDTO": {
      "type": "object",
      "properties": {
        "cost": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        },
        "shares": {
          "type": "number"
        }
      }
    },
    "http.PositionDTO": {
      "type": "object",
      "properties": {
        "base": {
          "$ref": "#/definitions/http.PositionBaseDTO"
        },
        "code": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "remark": {
          "type": "string"
        },
        "shares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        },
        "target": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.PositionTargetDTO"
          }
        }
      }
    },
    "http.PositionSnapshotAsOfDTO": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string"
        },
        "positions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/http.PositionSnapshotDTO"
          }
        }
      }
    },
    "http.PositionSnapshotDTO": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "price": {
          "type": "number"
        },
        "shares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        }
      }
    },
    "http.PositionSnapshotDatesDTO": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/http.PositionSnapshotDTO"
        }
      }
    },
    "http.PositionTargetDTO": {
      "type": "object",
      "properties": {
        "cost": {
          "type": "number"
        },
        "date": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "remark": {
          "type": "string"
        },
        "shares": {
          "type": "number"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "http.PositionUpdateRequest": {
      "type": "object",
      "required": ["code"],
      "properties": {
        "code": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "price": {
          "type": "number"
        },
        "shares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        }
      }
    },
    "http.ReviewRequest": {
      "type": "object",
      "properties": {
        "feeling": {
          "type": "string"
        },
        "market": {
          "type": "string"
        },
        "nextPlan": {
          "type": "string"
        }
      }
    },
    "http.SwingRecordRequest": {
      "type": "object",
      "properties": {
        "buyDate": {
          "type": "string"
        },
        "desc": {
          "type": "string"
        },
        "fee": {
          "type": "number"
        },
        "grossProfit": {
          "type": "number"
        },
        "netRevenue": {
          "type": "number"
        },
        "sellDate": {
          "type": "string"
        },
        "stock": {
          "type": "string"
        },
        "tax": {
          "type": "number"
        }
      }
    },
    "http.TRecordRequest": {
      "type": "object",
      "properties": {
        "desc": {
          "type": "string"
        },
        "fee": {
          "type": "number"
        },
        "grossProfit": {
          "type": "number"
        },
        "netRevenue": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        },
        "tax": {
          "type": "number"
        }
      }
    },
    "http.TradeRequest": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "hasIssue": {
          "type": "boolean"
        },
        "price": {
          "type": "number"
        },
        "shares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        }
      }
    },
    "http.UnmatchedLegDTO": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "id": {
          "type": "integer"
        },
        "price": {
          "type": "number"
        },
        "remainingShares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        },
        "totalFee": {
          "type": "number"
        },
        "totalShares": {
          "type": "number"
        }
      }
    },
    "http.UnmatchedLegRequest": {
      "type": "object",
      "properties": {
        "action": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "remainingShares": {
          "type": "number"
        },
        "stock": {
          "type": "string"
        },
        "totalFee": {
          "type": "number"
        },
        "totalShares": {
          "type": "number"
        }
      }
    },
    "httpx.ErrorResponse": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
