{
  "private": true,
  "name": "interview",
  "version": "1.0.0",
  "scripts": {
    "dev": "dumi dev",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "build": "father build",
    "prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\"",
    "test": "umi-test",
    "test:coverage": "umi-test --coverage",
    "prepublishOnly": "npm run build",
    "lint": "dumi g tmp && npm run lint:js && npm run lint:prettier",
    "lint-staged:js": "eslint --fix --format=pretty",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty",
    "lint:prettier": "prettier --check \"src/**/*\" --end-of-line auto",
    "prepare": "husky install",
    "upload": "node upload-to-r2.js",
    "deploy": "npm run docs:build && npm run upload",
    "mobile:build": "MOBILE=1 npm run docs:build && npx cap sync ios"
  },
  "files": [
    "dist"
  ],
  "module": "dist/esm/index.js",
  "typings": "dist/esm/index.d.ts",
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint-staged"
    }
  },
  "gitHooks": {
    "pre-commit": "lint-staged",
    "commit-msg": "commitlint -e $HUSKY_GIT_PARAMS"
  },
  "lint-staged": {
    "**/*.{js,jsx,tsx,ts,less,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.832.0",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@types/codemirror": "^5.60.17",
    "codemirror": "^5.65.21",
    "dotenv": "^16.5.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "marked": "^4.3.0",
    "mermaid": "^10.9.6",
    "react": "^18.0.0",
    "react-photo-view": "^1.2.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.15.1",
    "@testing-library/react": "^13.0.0",
    "@types/jest": "^27.0.3",
    "@types/node": "^24.0.13",
    "@umijs/fabric": "^2.8.1",
    "@umijs/test": "^3.0.5",
    "dumi": "^1.1.0",
    "father": "^4.0.0-rc.2",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^10.0.7",
    "prettier": "^2.2.1",
    "yorkie": "^2.0.0"
  },
  "checkFiles": [
    "src/**/*.js*",
    "src/**/*.ts*",
    "src/**/*.less",
    "config/**/*.js*",
    "scripts/**/*.js"
  ]
}
